{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git push *)",
            "command": "$HOME/.claude/hooks/codex-gate.sh"
          },
          {
            "type": "command",
            "if": "Bash(gh pr create *)",
            "command": "$HOME/.claude/hooks/codex-gate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(codex review *)",
            "command": "$HOME/.claude/hooks/codex-gate-pass.sh"
          },
          {
            "type": "command",
            "if": "Bash(codex-review-capture *)",
            "command": "$HOME/.claude/hooks/codex-gate-pass.sh"
          }
        ]
      }
    ]
  }
}
