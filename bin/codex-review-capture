#!/bin/bash
# ABOUTME: Wrapper around `codex review` that captures the full transcript to
# ABOUTME: a /tmp file (owner-only, auto-cleaned on reboot), prints only the
# ABOUTME: verdict -- content after the last `^codex$` marker -- to stdout, and
# ABOUTME: after a successful review with a recognized mode flag, promotes a
# ABOUTME: hash-keyed sentinel file that codex-gate.sh uses to admit one
# ABOUTME: subsequent push/pr-create of the reviewed diff.

set -uo pipefail

if command -v sha256sum >/dev/null 2>&1; then
    _sha256() { sha256sum | cut -d' ' -f1; }
elif command -v shasum >/dev/null 2>&1; then
    _sha256() { shasum -a 256 | cut -d' ' -f1; }
else
    _sha256() { return 1; }
fi

# Detect codex review mode and capture (BASE, HASH) for exactly the diff codex
# will see. We do this BEFORE running codex so a long-running review's race
# against working-tree edits doesn't change what we record.
review_mode=""
review_arg=""
argv=("$@")
# `codex review` (clap parser) accepts both `--flag value` and `--flag=value`
# forms. We handle both. Last flag wins on conflict.
for ((i=0; i<${#argv[@]}; i++)); do
    case "${argv[i]}" in
        --commit)      review_mode="commit";      review_arg="${argv[i+1]:-}" ;;
        --commit=*)    review_mode="commit";      review_arg="${argv[i]#--commit=}" ;;
        --base)        review_mode="base";        review_arg="${argv[i+1]:-}" ;;
        --base=*)      review_mode="base";        review_arg="${argv[i]#--base=}" ;;
        --uncommitted) review_mode="uncommitted"; review_arg="" ;;
    esac
done

review_base=""
review_hash=""
repo_name=""
if topdir=$(git rev-parse --show-toplevel 2>/dev/null); then
    repo_name=$(basename "$topdir")
    case "$review_mode" in
        commit)
            if [[ -n "$review_arg" ]] && review_base=$(git rev-parse "${review_arg}^" 2>/dev/null); then
                review_hash=$(git diff "${review_arg}^" "${review_arg}" 2>/dev/null | _sha256) || review_hash=""
            fi
            ;;
        base)
            if [[ -n "$review_arg" ]] && review_base=$(git merge-base "$review_arg" HEAD 2>/dev/null); then
                review_hash=$(git diff "$review_base" HEAD 2>/dev/null | _sha256) || review_hash=""
            fi
            ;;
        uncommitted)
            if review_base=$(git rev-parse HEAD 2>/dev/null); then
                # `codex review --uncommitted` covers staged, unstaged, AND
                # untracked changes. `git diff HEAD` only sees staged + unstaged,
                # so an untracked-only review would record an empty-diff hash and
                # the gate would over-block once those files are committed. Fail
                # closed: if untracked files are present, refuse to write the
                # staged file. The user must `git add` them first.
                # `git ls-files --others` is cwd-scoped without explicit paths,
                # so we use `-C "$topdir"` to scan the whole repo regardless of
                # where the wrapper was invoked.
                untracked=$(git -C "$topdir" ls-files --others --exclude-standard 2>/dev/null)
                if [[ -n "$untracked" ]]; then
                    printf 'codex-review-capture: --uncommitted review includes untracked files,\n' >&2
                    printf 'but the gate cannot verify them. Stage them with `git add` first,\n' >&2
                    printf 'then re-run codex-review-capture.\n\nUntracked:\n%s\n' "$untracked" >&2
                    review_base=""
                else
                    review_hash=$(git diff HEAD 2>/dev/null | _sha256) || review_hash=""
                fi
            fi
            ;;
    esac
fi

# Refuse to write a sentinel for an empty diff. sha256 of empty input is a
# well-known constant; the gate would otherwise allow a push from any clean
# tree state (regardless of which commits are about to be pushed), since
# `git diff HEAD` on a clean tree is empty and re-hashes to the same value.
# Pre-existing safety hole; closed during the hash-keyed redesign.
EMPTY_DIFF_HASH="e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
if [[ -n "$review_hash" && "$review_hash" == "$EMPTY_DIFF_HASH" ]]; then
    printf 'codex-review-capture: review diff is empty; refusing to write gate sentinel.\n' >&2
    printf 'There is nothing for codex to verify, and an empty-diff sentinel would\n' >&2
    printf 'false-allow any push from this clean state.\n' >&2
    review_base=""
    review_hash=""
fi

# Short-circuit if this exact diff hash has already been reviewed (and the
# cache is verifiable against the current tree). The wrapper does NOT replay
# the original verdict -- if you need fresh findings, delete the cached file
# -- but the gate is unblocked since the safety property (codex saw this
# diff content) holds.
#
# Re-validate the cached BASE against the current tree before trusting the
# cache. The cache filename keys on diff hash alone; two different (base,
# current_tree) pairs can produce the same diff content (e.g., adding an
# identical new file on different branches with different committed trees).
# Without re-validation we'd short-circuit on a sentinel whose BASE doesn't
# describe the current tree, and the gate would later block because `git diff
# cached_base` against the current tree produces a hash that doesn't match
# the cache filename.
if [[ -n "$review_base" && -n "$review_hash" && -n "$repo_name" ]]; then
    cached="/tmp/codex-gate-reviewed-${UID}-${repo_name}-${review_hash}"
    if [[ -f "$cached" ]]; then
        cached_base=$(< "$cached")
        if git rev-parse --verify "${cached_base}^{commit}" >/dev/null 2>&1; then
            cached_diff_hash=$(git diff "$cached_base" 2>/dev/null | _sha256) || cached_diff_hash=""
            if [[ "$cached_diff_hash" == "$review_hash" ]]; then
                printf 'codex-review-capture: hash %s already reviewed; gate unblocked.\n' "${review_hash:0:12}" >&2
                printf 'Delete %s to force a fresh review.\n' "$cached" >&2
                exit 0
            fi
        fi
        # Cache is unusable -- unreachable base, or stale base that no longer
        # produces a matching hash against the current tree. Drop it.
        rm -f "$cached"
    fi
fi

staged=""
if [[ -n "$review_base" && -n "$review_hash" && -n "$repo_name" ]]; then
    staged="/tmp/codex-gate-staged-${UID}-${repo_name}-$$"
    printf '%s\n' "$review_base" > "$staged"
    printf 'codex-review-capture: staged=%s\n' "$staged" >&2
fi

output=$(mktemp -t codex-review.XXXXXXXX)
printf 'codex-review-capture: full transcript -> %s\n' "$output" >&2

# Touched before `codex review` so the post-run session-file scan can prune to
# files this invocation could have produced. `find -newer <ref>` is portable to
# BSD/macOS; `-newermt "@<epoch>"` is not (the @epoch time syntax is GNU-only).
review_marker=$(mktemp -t codex-review-start.XXXXXXXX)

# Wallclock around `codex review` so the tokens summary can report how long
# the run actually took. Clamp at zero in case the clock went backwards
# (NTP step, manual `date` set, suspend/resume) -- format_elapsed prints
# negative values literally, and a negative elapsed would also fail the
# test's `elapsed=[0-9]+s` regex.
review_start=$(date +%s)
codex review "$@" >"$output" 2>&1
rc=$?
review_elapsed=$(( $(date +%s) - review_start ))
(( review_elapsed < 0 )) && review_elapsed=0

# Insert thousands separators into a non-negative integer string.
commafy() {
    local n="$1" r=""
    while ((${#n} > 3)); do
        r=",${n: -3}$r"
        n="${n:0:${#n}-3}"
    done
    printf '%s%s' "$n" "$r"
}

# Format a non-negative integer of seconds as a compact duration:
# 47 -> "47s", 134 -> "2m14s", 3725 -> "1h02m05s".
format_elapsed() {
    local secs="$1"
    if (( secs < 60 )); then
        printf '%ds' "$secs"
    elif (( secs < 3600 )); then
        printf '%dm%02ds' $((secs / 60)) $((secs % 60))
    else
        printf '%dh%02dm%02ds' $((secs / 3600)) $(((secs % 3600) / 60)) $((secs % 60))
    fi
}

# OpenAI standard-tier prices per 1M tokens: "<short_in> <short_cached> <short_out> <long_in> <long_cached> <long_out>".
# Short tier applies when a turn's input < SHORT_CONTEXT_THRESHOLD; long otherwise. Cost is summed per-turn.
# Unmapped models drop cost entirely (token counts still reported).
SHORT_CONTEXT_THRESHOLD=272000
price_table() {
    case "$1" in
        gpt-5.5) echo "5 0.5 30 10 1 45" ;;
        gpt-5.4) echo "2.5 0.25 15 5 0.5 22.5" ;;
    esac
}

# Surface codex's own token-usage event so callers can report run cost.
# `codex review` persists `token_count` events to a session JSONL under
# ${CODEX_HOME:-$HOME/.codex}/sessions/YYYY/MM/DD/rollout-*.jsonl. The session id
# printed in codex's stdout transcript is the parent orchestrator's id, not the
# id of the persisted sub-agent session — so we locate the right file by:
# (a) mtime newer than review_marker, (b) session_meta source.subagent=="review",
# (c) session_meta cwd matches $PWD. If multiple match, pick the newest by
# session_meta.timestamp (concurrent same-cwd runs may swap reports — acceptable).
# Python (the codex-gate hooks' canonical JSON parser) handles all parsing in
# one pass; failures are non-fatal so review output is unaffected.
report_token_usage() {
    command -v python3 >/dev/null 2>&1 || return 0
    local sessions_root="${CODEX_HOME:-$HOME/.codex}/sessions"
    [[ -d "$sessions_root" ]] || return 0
    [[ -e "$review_marker" ]] || return 0

    local candidates=()
    while IFS= read -r -d '' candidate; do
        candidates+=("$candidate")
    done < <(find "$sessions_root" -type f -name '*.jsonl' -newer "$review_marker" -print0 2>/dev/null)
    [[ ${#candidates[@]} -gt 0 ]] || return 0

    # Single python pass: pick the matching session file, then emit:
    #   line 1: model (possibly empty)
    #   line 2: <input> <cached> <output> <reasoning> <total>   (cumulative final)
    #   line N: <input> <cached> <output>   (per-event cumulative for cost deltas)
    # Empty output means "no matching session file or no usable token_count events".
    local extracted
    extracted=$(python3 - "$PWD" "${candidates[@]}" 2>/dev/null <<'PYEOF'
import json, sys
target_cwd = sys.argv[1]
best_path, best_ts = None, ""
# `codex review` writes two session files per invocation: the orchestrator
# (source == "exec", a bare string) and the review sub-agent (source ==
# {"subagent": "review"}, a dict). We want the latter — `isinstance` keeps the
# loop alive when iterating past the orchestrator's differently-shaped meta.
for path in sys.argv[2:]:
    try:
        with open(path, encoding="utf-8") as f:
            ev = json.loads(f.readline())
        p = ev.get("payload") if isinstance(ev, dict) else None
        if not isinstance(p, dict) or ev.get("type") != "session_meta":
            continue
        src = p.get("source")
        if not isinstance(src, dict) or src.get("subagent") != "review":
            continue
        if p.get("cwd") != target_cwd:
            continue
        ts = p.get("timestamp", "")
        if best_path is None or ts > best_ts:
            best_path, best_ts = path, ts
    except (OSError, ValueError, AttributeError, TypeError):
        continue
if best_path is None:
    sys.exit(0)
model, final_total, rows = "", None, []
fields = ("input_tokens", "cached_input_tokens", "output_tokens",
          "reasoning_output_tokens", "total_tokens")
with open(best_path, encoding="utf-8") as f:
    for line in f:
        try:
            ev = json.loads(line)
            t = ev.get("type") if isinstance(ev, dict) else None
            p = ev.get("payload") if isinstance(ev, dict) else None
            if not isinstance(p, dict):
                continue
            if t == "turn_context" and not model:
                m = p.get("model")
                if isinstance(m, str) and m:
                    model = m
            elif t == "event_msg" and p.get("type") == "token_count":
                info = p.get("info")
                tot = info.get("total_token_usage") if isinstance(info, dict) else None
                if not isinstance(tot, dict):
                    continue
                vals = [tot.get(k) for k in fields]
                if any(not isinstance(v, int) for v in vals):
                    continue
                final_total = vals
                rows.append((vals[0], vals[1], vals[2]))
        except (ValueError, AttributeError, TypeError):
            continue
print(model)
if final_total is not None:
    print(" ".join(str(v) for v in final_total))
    for r in rows:
        print(" ".join(str(v) for v in r))
PYEOF
    )
    [[ -n "$extracted" ]] || return 0

    local model final_total_line
    { IFS= read -r model
      IFS= read -r final_total_line || true
    } <<<"$extracted"
    [[ -n "$final_total_line" ]] || return 0

    local in_t ca_t ou_t re_t to_t
    read -r in_t ca_t ou_t re_t to_t <<<"$final_total_line"

    local summary
    summary="input=$(commafy "$in_t") cached=$(commafy "$ca_t") output=$(commafy "$ou_t") reasoning=$(commafy "$re_t") total=$(commafy "$to_t")"

    # Cost is per-turn tiered: each row's delta of `total_token_usage` is a
    # per-turn snapshot, and its delta-input decides short/long-context tier.
    # Deltas naturally absorb the duplicate token_count events that real codex
    # emits per turn — a duplicate row delta is (0,0,0), contributing $0.
    local rates
    rates=$(price_table "$model")
    if [[ -n "$rates" ]]; then
        # Variable names si/sc/so/li/lc/lo avoid gawk builtin clashes (sin, or, etc.).
        local si sc so li lc lo
        read -r si sc so li lc lo <<<"$rates"
        # Drop the first two lines (model, final cumulative) — the rest are
        # per-event cumulative rows for delta-based cost calculation.
        local rows
        rows=$(printf '%s\n' "$extracted" | tail -n +3)
        if [[ -n "$rows" ]]; then
            local cost
            cost=$(printf '%s\n' "$rows" | awk \
                -v si="$si" -v sc="$sc" -v so="$so" \
                -v li="$li" -v lc="$lc" -v lo="$lo" \
                -v thr="$SHORT_CONTEXT_THRESHOLD" '
                { di = $1 - pi; dc = $2 - pc; doo = $3 - po
                  if (di+0 >= thr) cost += (di - dc) * li + dc * lc + doo * lo
                  else             cost += (di - dc) * si + dc * sc + doo * so
                  pi = $1; pc = $2; po = $3 }
                END { printf "%.4f", cost / 1000000 }')
            summary+=" cost=\$$cost"
        fi
    fi
    [[ -n "$model" ]] && summary+=" model=$model"
    # Elapsed lives on the tokens line by design: callers (the codex-review
    # skill) pass this line through verbatim, and bundling avoids a second
    # stderr line. The coupling means an early `return 0` above also
    # suppresses elapsed; intentional (no point reporting timing on
    # transcripts the wrapper couldn't measure).
    summary+=" elapsed=$(format_elapsed "$review_elapsed")"

    printf 'codex-review-capture: tokens %s\n' "$summary" >&2
}
report_token_usage
rm -f "$review_marker"

if [[ $rc -ne 0 && -n "$staged" ]]; then
    rm -f "$staged"
fi

# Promote the staged file to its hash-keyed reviewed sentinel. No env vars,
# no session id, no JSON channel: the filename suffix encodes the diff hash
# (already in $review_hash) and the gate scans for any file matching its
# own recomputed hash. Works identically for foreground and background tool
# calls.
if [[ -n "$staged" && -f "$staged" && -n "$review_hash" ]]; then
    if ! mv "$staged" "/tmp/codex-gate-reviewed-${UID}-${repo_name}-${review_hash}"; then
        printf 'codex-review-capture: failed to promote staged file to sentinel\n' >&2
    fi
fi

if grep -q '^codex$' "$output"; then
    # Keep only the block after the LAST `^codex$` marker: reset buffer on each
    # match, then print whatever remains at EOF.
    awk '/^codex$/ { buf = ""; next } { buf = buf $0 ORS } END { printf "%s", buf }' "$output"
else
    printf 'codex-review-capture: no ^codex$ marker in output; printing full transcript.\n' >&2
    cat "$output"
fi

exit "$rc"
