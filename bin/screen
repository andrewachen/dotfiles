#!/bin/bash
# ABOUTME: Compatibility wrapper that maps common GNU screen invocations to tmux.
# ABOUTME: Named attach falls back to /usr/bin/screen on tmux miss; other modes fail loudly.

set -uo pipefail

original_args=("$@")

tmux_bin=${TMUX_SCREEN_COMPAT_TMUX:-tmux}
screen_bin=${TMUX_SCREEN_COMPAT_REAL_SCREEN:-/usr/bin/screen}

session_name=
target=
list_sessions=false
attach_requested=false
attach_via_x=false
create_if_missing=false
detach_requested=false
detach_others=false
force_new=false
unsupported=()
positionals=()
cluster_needs_session_name=false

usage() {
    cat <<'EOF'
screen: tmux-backed screen compatibility wrapper

Supported:
  screen
  screen -S NAME [COMMAND ...]
  screen -r [NAME]
  screen -x [NAME]
  screen -d [NAME]
  screen -D [NAME]
  screen -d -r [NAME]
  screen -D -r [NAME]
  screen -D -RR [NAME]
  screen -R|-RR [NAME]
  screen -ls|-list|-l
  screen -dmS NAME [COMMAND ...]

In this wrapper, -D detaches other tmux clients without sending SIGHUP/logout.

Unsupported screen options do not fall back to GNU screen.

Fallback: if a named-target attach (-r, -x, -d -r, -D -r) finds no matching
tmux session and /usr/bin/screen lists one whose name starts with the
target (prefix match, like screen -r itself), the wrapper hands off to GNU
screen with the original arguments. Other modes do not fall back.

Listing: -ls / -l / -list emits tmux sessions first, then GNU screen
sessions (separated by a blank line) when /usr/bin/screen is available.

Use tmux directly for behavior outside this compatibility set.
EOF
}

die() {
    printf 'screen: %s\n' "$*" >&2
    printf 'screen: this is a tmux-backed screen compatibility wrapper; unsupported screen args do not fall back to GNU screen.\n' >&2
    printf 'screen: run "screen --help" for supported compatibility flags.\n' >&2
    exit 2
}

need_value() {
    local opt=$1
    if (($# < 2)) || [[ -z ${2-} ]]; then
        die "$opt requires an argument"
    fi
}

require_tmux() {
    if ! command -v "$tmux_bin" >/dev/null 2>&1; then
        printf 'screen: tmux is required for this compatibility wrapper, but "%s" was not found.\n' "$tmux_bin" >&2
        exit 127
    fi
}

run_tmux() {
    require_tmux
    exec "$tmux_bin" "$@"
}

join_command() {
    local out=
    local quoted=
    local word=

    for word in "$@"; do
        printf -v quoted '%q' "$word"
        if [[ -n $out ]]; then
            out+=" "
        fi
        out+="$quoted"
    done

    printf '%s' "$out"
}

parse_cluster() {
    local arg=$1
    local chars=${arg#-}
    local ch

    while [[ -n $chars ]]; do
        ch=${chars:0:1}
        chars=${chars:1}

        case "$ch" in
            d)
                detach_requested=true
                ;;
            D)
                detach_requested=true
                detach_others=true
                ;;
            m)
                force_new=true
                ;;
            r|x)
                attach_requested=true
                if [[ $ch == x ]]; then
                    attach_via_x=true
                fi
                if [[ -n $chars ]]; then
                    target=$chars
                    chars=
                fi
                ;;
            R)
                attach_requested=true
                create_if_missing=true
                ;;
            S)
                if [[ -n $chars ]]; then
                    session_name=$chars
                    chars=
                else
                    cluster_needs_session_name=true
                fi
                ;;
            *)
                unsupported+=("-$ch")
                ;;
        esac
    done
}

while (($#)); do
    case "$1" in
        --)
            shift
            positionals+=("$@")
            break
            ;;
        -h|--help|-help)
            usage
            exit 0
            ;;
        -ls|-list|--list|-l)
            list_sessions=true
            shift
            ;;
        -S)
            shift
            need_value "-S" "${1-}"
            session_name=$1
            shift
            ;;
        -S*)
            session_name=${1#-S}
            shift
            ;;
        -*)
            arg=$1
            shift
            cluster_needs_session_name=false
            parse_cluster "$arg"
            if [[ $cluster_needs_session_name == true ]]; then
                need_value "-S" "${1-}"
                session_name=$1
                shift
            fi
            ;;
        *)
            positionals+=("$@")
            break
            ;;
    esac
done

if ((${#unsupported[@]})); then
    die "unsupported option(s): ${unsupported[*]}"
fi

if [[ $list_sessions == true ]]; then
    if [[ -n $session_name || $attach_requested == true || $detach_requested == true || $force_new == true || ${#positionals[@]} -gt 0 ]]; then
        die "session listing cannot be combined with other screen options"
    fi
    require_tmux
    tmux_out=$("$tmux_bin" list-sessions 2>/dev/null) || true
    [[ -n $tmux_out ]] && printf '%s\n' "$tmux_out"

    screen_rc=1
    if [[ -x $screen_bin ]] && ! [[ $screen_bin -ef ${BASH_SOURCE[0]} ]]; then
        [[ -n $tmux_out ]] && printf '\n'
        "$screen_bin" -ls 2>/dev/null
        screen_rc=$?
    fi
    if [[ -n $tmux_out ]] || (( screen_rc == 0 )); then
        exit 0
    fi
    exit 1
fi

if [[ $attach_requested == true ]]; then
    if [[ -z $target && ${#positionals[@]} -gt 0 ]]; then
        target=${positionals[0]}
        positionals=("${positionals[@]:1}")
    fi

    if ((${#positionals[@]})); then
        die "attach mode accepts at most one session name"
    fi

    if [[ -z $target && -n $session_name ]]; then
        target=$session_name
    fi

    if [[ $create_if_missing == true ]]; then
        if [[ -n $target ]]; then
            args=(new-session -A -s "$target")
            if [[ $detach_requested == true || $detach_others == true ]]; then
                args=(new-session -A -D -s "$target")
            fi
            run_tmux "${args[@]}"
        fi

        require_tmux
        args=(attach-session)
        if [[ $detach_requested == true || $detach_others == true ]]; then
            args+=( -d )
        fi

        if "$tmux_bin" list-sessions >/dev/null 2>&1; then
            run_tmux "${args[@]}"
        fi

        run_tmux new-session
    fi

    # tmux's `has-session -t <prefix>` returns non-zero for both "no match"
    # and "ambiguous prefix matches multiple sessions", so we can't use it
    # to gate the GNU screen fallback — an ambiguous tmux prefix would leak
    # through to screen. Ask tmux for the session names and prefix-match
    # ourselves; only fall back when tmux has zero candidates.
    if [[ -n $target ]] && ! { "$tmux_bin" list-sessions -F '#{session_name}' 2>/dev/null || true; } \
        | awk -v t="$target" 'substr($0, 1, length(t)) == t { found=1 } END { exit !found }'; then
        if [[ -x $screen_bin ]] && ! [[ $screen_bin -ef ${BASH_SOURCE[0]} ]]; then
            if { "$screen_bin" -ls 2>/dev/null || true; } \
                | awk -v t="$target" '$1 ~ /^[0-9]+\./ {
                      n = $1; sub(/^[0-9]+\./, "", n)
                      if (substr(n, 1, length(t)) == t) found = 1
                  } END { exit !found }'; then
                exec "$screen_bin" "${original_args[@]}"
            fi
        fi
    fi

    # screen -x NAME (bare, with target, no detach) → independent view via
    # tmux session group. Create a shadow session NAME-x-<wrapper-pid> grouped
    # with NAME, attach to the shadow, and kill the shadow on detach via
    # EXIT trap. Other -x variants (-dx, -Dx) and -r fall through to plain
    # attach-session below.
    if [[ $attach_via_x == true && -n $target && $detach_requested == false && $create_if_missing == false ]]; then
        require_tmux
        if "$tmux_bin" has-session -t "$target" 2>/dev/null; then
            # tmux's -t accepts unique prefixes; resolve $target to the real
            # session name so shadow naming and orphan-prune group matching
            # use the canonical anchor, not whatever prefix the user typed.
            # `$target:` forces session-target parsing — without the colon,
            # display-message resolves -t as a target-pane, which from inside
            # a tmux session can pick a window of the current session that
            # happens to share the target's name.
            canonical_target=$("$tmux_bin" display-message -t "$target:" -p '#{session_name}' 2>/dev/null)
            if [[ -n $canonical_target ]]; then
                target=$canonical_target
            fi

            shadow_name="$target-x-$$"

            # Prune orphan shadows from previously-killed wrappers in the
            # same family. Pattern: <target>-x-<digits>; the digits are the
            # wrapper PID at creation time. If kill -0 fails, the wrapper
            # is gone and the shadow is a ghost — drop it.

            # Resolve target's actual session group. When the user pre-groups
            # sessions outside the wrapper (e.g., `tmux new -t devgrp -s foo`),
            # the group's name is NOT the target's name, and our shadow will
            # inherit that group. For standalone sessions, session_group is
            # empty — but our future shadow will create a new group whose
            # name defaults to $target, so $target is the right value.
            target_group=$("$tmux_bin" display-message -t "$target:" -p '#{session_group}' 2>/dev/null)
            [[ -z $target_group ]] && target_group=$target

            # Only consider sessions in $target's session group. The name
            # pattern alone is not enough — a user could have a legitimate
            # session named NAME-x-<digits> that has nothing to do with this
            # wrapper, and we must not kill it.
            while IFS='|' read -r existing existing_group; do
                [[ -z $existing ]] && continue
                [[ $existing_group != "$target_group" ]] && continue
                rest=${existing#"$target-x-"}
                if [[ $rest != "$existing" && $rest =~ ^[0-9]+$ ]]; then
                    if ! kill -0 "$rest" 2>/dev/null; then
                        "$tmux_bin" kill-session -t "$existing" 2>/dev/null || true
                    fi
                fi
            done < <("$tmux_bin" list-sessions -F '#{session_name}|#{session_group}' 2>/dev/null || true)

            # Clean up our own shadow on any exit path. tmux kill-session
            # is idempotent (we silence "no such session"), so a duplicate
            # cleanup from a fast user-initiated kill is harmless.
            cleanup_shadow() {
                "$tmux_bin" kill-session -t "$shadow_name" 2>/dev/null || true
            }
            trap cleanup_shadow EXIT INT TERM HUP

            "$tmux_bin" new-session -t "$target" -s "$shadow_name"
            exit $?
        fi
    fi

    args=(attach-session)
    if [[ $detach_requested == true || $detach_others == true ]]; then
        args+=( -d )
    fi
    if [[ -n $target ]]; then
        args+=( -t "$target" )
    fi

    run_tmux "${args[@]}"
fi

if [[ $detach_requested == true && $force_new == false ]]; then
    if [[ -z $target && ${#positionals[@]} -gt 0 ]]; then
        target=${positionals[0]}
        positionals=("${positionals[@]:1}")
    fi

    if ((${#positionals[@]})); then
        die "detach mode accepts at most one session name"
    fi

    if [[ -z $target && -n $session_name ]]; then
        target=$session_name
    fi

    args=(detach-client)
    if [[ -n $target ]]; then
        args+=( -s "$target" )
    fi

    run_tmux "${args[@]}"
fi

args=(new-session)

if [[ $detach_requested == true && $force_new == true ]]; then
    args+=( -d )
fi

if [[ -n $session_name ]]; then
    args+=( -s "$session_name" )
fi

if ((${#positionals[@]})); then
    args+=( "$(join_command "${positionals[@]}")" )
fi

run_tmux "${args[@]}"
